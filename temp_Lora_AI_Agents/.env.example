# ═══════════════════════════════════════════
# APP
# ═══════════════════════════════════════════
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3001
API_URL=http://localhost:3000

# JWT (kept for legacy/test use; Supabase JWT is the primary auth path)
JWT_SECRET=replace-with-32-char-random-string-min-length-32
JWT_EXPIRY=15m
JWT_REFRESH_SECRET=replace-with-different-refresh-secret-min-32
JWT_REFRESH_EXPIRY=30d

# ═══════════════════════════════════════════
# SUPABASE (Auth + Users)
# ═══════════════════════════════════════════
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Found in: Supabase Dashboard → Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
# Frontend (public)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Encryption (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=replace-with-64-hex-char-string-32-bytes

# ═══════════════════════════════════════════
# DATABASES
# ═══════════════════════════════════════════
DATABASE_URL=postgresql://loraloop:loraloop_secret@localhost:5432/loraloop_db
ANALYTICS_DATABASE_URL=postgresql://loraloop:loraloop_secret@localhost:5433/loraloop_analytics

# ═══════════════════════════════════════════
# CACHE & QUEUES (Redis)
# ═══════════════════════════════════════════
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ═══════════════════════════════════════════
# EVENT BUS (Kafka)
# ═══════════════════════════════════════════
KAFKA_BROKERS=localhost:9092
KAFKA_SSL=false
KAFKA_USERNAME=
KAFKA_PASSWORD=
KAFKA_GROUP_ID=loraloop-api
KAFKA_CLIENT_ID=loraloop-api

# ═══════════════════════════════════════════
# VECTOR DATABASE (Qdrant)
# ═══════════════════════════════════════════
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ═══════════════════════════════════════════
# AI MODELS — Intelligent LLM Router
# Only these 6 providers are supported.
# Set at least one key to enable routing.
# ═══════════════════════════════════════════

# Anthropic — Claude Haiku 4.5 (low) / Sonnet 4.6 (medium) / Opus 4.7 (high)
# Best for: coding, analysis, agent tasks
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI — GPT-4o-mini (low) / GPT-4.1 / GPT-4o (medium) / o3-mini (high)
# Also enables: DALL-E image generation, Whisper transcription, TTS
# Best for: creative, coding, image gen, audio
OPENAI_API_KEY=sk-your-openai-key-here

# Google Gemini — Flash 2.0 (low) / 2.5 Pro (medium/high)
# Also enables: Imagen 3 image generation, Veo 3 video generation
# Best for: long context, analysis, cheap routing advisor
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza-your-gemini-key

# xAI — Grok 3 Mini (low) / Grok 3 (medium/high)
# Best for: creative tasks, live internet context
# Get key: https://console.x.ai
XAI_API_KEY=xai-your-key-here

# Meta Llama via Groq (fastest inference for cheap tasks)
# Models: Llama 3.3 70B / Llama 4 Maverick
# Get key: https://console.groq.com
GROQ_API_KEY=gsk_your-groq-key-here

# Perplexity — Sonar (standard) / Sonar Pro / Sonar Reasoning
# REQUIRED for real-time/web/research tasks ("latest news", "current trends", etc.)
# Get key: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-your-key-here

# ─── Router feature flags ────────────────────────────────────────────────────
# Uncomment to disable specific providers even if key is set
# ENABLE_ANTHROPIC=true
# ENABLE_OPENAI=true
# ENABLE_GOOGLE=true
# ENABLE_XAI=true
# ENABLE_META=true
# ENABLE_PERPLEXITY=true

# ═══════════════════════════════════════════
# STORAGE (Cloudflare R2)
# ═══════════════════════════════════════════
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=loraloop-media
R2_PUBLIC_URL=https://cdn.yourdomain.com

# ═══════════════════════════════════════════
# EMAIL
# ═══════════════════════════════════════════
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=your-resend-api-key
EMAIL_FROM=noreply@yourdomain.com
# Resend SDK (preferred — cleaner than raw SMTP)
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@loraloop.ai
RESEND_FROM_NAME=Loraloop

# ═══════════════════════════════════════════
# MONITORING
# ═══════════════════════════════════════════
SENTRY_DSN=
LOG_LEVEL=debug

# ═══════════════════════════════════════════
# PLATFORM API KEYS — META (Instagram + Facebook)
# ═══════════════════════════════════════════
META_CLIENT_ID=your-meta-app-id
META_CLIENT_SECRET=your-meta-app-secret
META_REDIRECT_URI=http://localhost:3000/v1/connections/callback?platform=instagram

# ═══════════════════════════════════════════
# PLATFORM API KEYS — TIKTOK
# ═══════════════════════════════════════════
TIKTOK_CLIENT_KEY=your-tiktok-client-key
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret
TIKTOK_REDIRECT_URI=http://localhost:3000/v1/connections/callback?platform=tiktok

# ═══════════════════════════════════════════
# PLATFORM API KEYS — TWITTER / X
# ═══════════════════════════════════════════
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-client-secret
TWITTER_REDIRECT_URI=http://localhost:3000/v1/connections/callback?platform=twitter
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
TWITTER_BEARER_TOKEN=your-twitter-bearer-token

# ═══════════════════════════════════════════
# PLATFORM API KEYS — LINKEDIN
# ═══════════════════════════════════════════
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_REDIRECT_URI=http://localhost:3000/v1/connections/callback?platform=linkedin

# ═══════════════════════════════════════════
# PLATFORM API KEYS — YOUTUBE (Google)
# ═══════════════════════════════════════════
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/v1/connections/callback?platform=youtube

# ═══════════════════════════════════════════
# PLATFORM API KEYS — PINTEREST
# ═══════════════════════════════════════════
PINTEREST_APP_ID=your-pinterest-app-id
PINTEREST_APP_SECRET=your-pinterest-app-secret
PINTEREST_REDIRECT_URI=http://localhost:3000/v1/connections/callback?platform=pinterest

# ═══════════════════════════════════════════
# FRONTEND ENV
# ═══════════════════════════════════════════
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3000
NEXT_PUBLIC_SENTRY_DSN=
